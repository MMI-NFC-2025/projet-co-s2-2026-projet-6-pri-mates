---
import Tel from '../assets/icon/icon_tel.svg'
import Mail from '../assets/icon/icon_enveloppe.svg'
---
<footer class="bg-rose-950 text-white">
    <div class="mx-auto flex max-w-[1120px] flex-col px-10 py-10 lg:px-6 lg:py-12">
        <nav aria-label="Footer" class="flex flex-col gap-8">
            <div class="grid grid-cols-1 gap-6 text-[22px] sm:grid-cols-3 sm:items-center sm:justify-items-center lg:px-20 lg:text-[24px]">
                <a href="/">Accueil</a>
                <a href="/a_propos">À propos</a>
                <a href="/mentions">Mentions légales</a>
            </div>
            <div class="mx-auto h-px w-[94%] bg-white/55"></div>
            <div class="grid gap-8 lg:grid-cols-[1.15fr_0.95fr] lg:items-start lg:gap-12">
                <div class="space-y-5">
                    <p class="text-[28px] font-bold lg:text-[30px]">Nous contacter</p>
                    <ul class="flex flex-col gap-5 text-[18px] lg:gap-6 lg:text-[20px]">
                        <li>
                            <a href="tel:+33384711948" class="inline-flex items-center gap-1.5">
                                <Tel/>
                                <span>+33 3 84 71 19 48</span>
                            </a>
                        </li>
                        <li>
                            <a href="mailto:tacita@gmail.com" class="inline-flex items-center gap-1.5">
                                <Mail/>
                                <span>tacita@gmail.com</span>
                            </a>
                        </li>
                    </ul>
                </div>
                <p class="max-w-[560px] text-[19px] leading-[1.08] lg:justify-self-end lg:pt-10 lg:text-[21px]">
                    Projet réalisé en 2026 dans le cadre d’un exercice pédagogique au département <a href="/" class="underline underline-offset-[3px]">MMI de Montbéliard</a>
                </p>
            </div>
        </nav>
    </div>
</footer>